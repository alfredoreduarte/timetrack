# Staging Environment Configuration
# Ports 3020-3024 — fully isolated from production (3010-3014)

# Port Configuration
WEB_PORT=3020
API_PORT=3021
POSTGRES_PORT=3022
REDIS_PORT=3023
LANDING_PORT=3024

# PostgreSQL Database Configuration
# CRITICAL: Use different credentials from production
POSTGRES_PASSWORD=staging_secure_password_change_me

# JWT Configuration
JWT_SECRET=staging-jwt-secret-change-this-make-it-long-and-random

# Request Size Limiting Configuration
REQUEST_SIZE_AUTH=50kb
REQUEST_SIZE_TIME_ENTRIES=500kb
REQUEST_SIZE_PROJECTS=200kb
REQUEST_SIZE_USERS=100kb
REQUEST_SIZE_DEFAULT=1mb
REQUEST_SIZE_URLENCODED=1mb
REQUEST_SIZE_RAW=1mb
REQUEST_SIZE_TEXT=100kb

# XSS Protection & Content Security Policy
CSP_REPORT_ONLY=true
CSP_ALLOWED_DOMAINS=staging.track.alfredo.re,app.staging.track.alfredo.re,api.staging.track.alfredo.re
ENABLE_AGGRESSIVE_XSS_PROTECTION=false

# CORS Configuration
ALLOWED_ORIGINS=https://staging.track.alfredo.re,https://app.staging.track.alfredo.re

# Vite Environment Variables (exposed to frontend)
VITE_API_URL=https://api.staging.track.alfredo.re

# Application URL (used by API for links, emails, etc.)
APPLICATION_URL=https://app.staging.track.alfredo.re

# Redis Configuration
REDIS_PASSWORD=staging_redis_secure_password

# DEPLOYMENT NOTES:
# 1. Copy this file to docker.staging.env and fill in real credentials
# 2. Generate strong passwords: openssl rand -base64 32
# 3. Never commit docker.staging.env to git — it contains secrets
# 4. Deploy with: ./deploy.sh staging
