default_platform(:ios)

XCODE_PROJECT = "Timetrack/Timetrack.xcodeproj"
SCHEME        = "Timetrack"
APP_IDS = [
  "com.orbitalabworks.timetrack",
  "com.orbitalabworks.timetrack.watchkitapp",
  "com.orbitalabworks.timetrack.liveactivity"
]

def asc_api_key
  app_store_connect_api_key(
    key_id:              ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id:           ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key_content:         ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
    is_key_content_base64: true,
    in_house:            false
  )
end

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "One-time: seed App Store distribution certs & profiles into Match storage. Run locally."
  lane :match_setup do
    match(
      type:           "appstore",
      app_identifier: APP_IDS,
      api_key:        asc_api_key,
      readonly:       false,
      force_for_new_devices: false
    )
  end

  desc "Sync existing signing assets from Match (readonly). Useful sanity check."
  lane :match_sync do
    match(
      type:           "appstore",
      app_identifier: APP_IDS,
      api_key:        asc_api_key,
      readonly:       true
    )
  end

  desc "Build the iOS app and ship to TestFlight."
  lane :beta do |options|
    api_key = asc_api_key

    match(
      type:           "appstore",
      app_identifier: APP_IDS,
      api_key:        api_key,
      readonly:       true
    )

    next_build = latest_testflight_build_number(
      app_identifier:       APP_IDS.first,
      api_key:              api_key,
      initial_build_number: 0
    ) + 1

    increment_build_number(
      xcodeproj:    XCODE_PROJECT,
      build_number: next_build
    )

    build_app(
      project:          XCODE_PROJECT,
      scheme:           SCHEME,
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "build",
      output_name:      "Timetrack.ipa",
      clean:            true,
      include_symbols:  true,
      include_bitcode:  false,
      xcargs:           "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key:                          api_key,
      app_identifier:                   APP_IDS.first,
      skip_waiting_for_build_processing: true,
      changelog:                        options[:release_notes] || "Automated build #{next_build} from GitHub Actions"
    )
  end
end
